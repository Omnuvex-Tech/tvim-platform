{
    "extends": "@repo/typescript-config/nextjs.json",
    "compilerOptions": {
        "plugins": [
            {
                "name": "next"
            }
        ],
        "strictNullChecks": true,
        "paths": {
            "@/*": ["./*"],
            "@/config": ["./config/index.ts"],
            "@/config/*": ["./config/*"],
            "@/lib/*": ["./lib/*"]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "next-env.d.ts",
        "next.config.js",
        ".next/types/**/*.ts"
    ],
    "exclude": ["node_modules"]
}
